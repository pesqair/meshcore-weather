# Meshcore Weather Bot Configuration
# Copy this to .env and adjust values

# Serial port for the Meshcore radio
# macOS: /dev/cu.usbserial-0001
# Linux: /dev/ttyUSB0
MCW_SERIAL_PORT=/dev/cu.usbserial-0001
MCW_SERIAL_BAUD=115200

# Meshcore channel - name (e.g. #digitaino-wx-bot) or index (0-7)
MCW_MESHCORE_CHANNEL=#digitaino-wx-bot

# EMWIN data source: "internet" (default) or "sdr" (future)
MCW_EMWIN_SOURCE=internet

# How often to refresh EMWIN data (seconds)
MCW_EMWIN_POLL_INTERVAL=300

# Ollama LLM for natural language processing
# For Docker: MCW_OLLAMA_URL=http://ollama:11434/api/generate
MCW_OLLAMA_URL=http://localhost:11434/api/generate
MCW_OLLAMA_MODEL=mistral

# Admin pubkey prefix (from DM logs) - can run admin commands via DM
# MCW_ADMIN_KEY=cc62182a1234

# Logging level: DEBUG, INFO, WARNING, ERROR
MCW_LOG_LEVEL=INFO
